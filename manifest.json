{
  "manifest_version": 3,
  "name": "Skipisode",
  "version": "1.0.0",
  "description": "Manually save and auto-skip YouTube TV show intros and outros.",
  "icons": {
    "16": "logo/icons/icon16.png",
    "32": "logo/icons/icon32.png",
    "48": "logo/icons/icon48.png",
    "128": "logo/icons/icon128.png"
  },
  "permissions": ["storage"],
  "action": {
    "default_title": "Skipisode",
    "default_icon": {
      "16": "logo/icons/icon16.png",
      "32": "logo/icons/icon32.png",
      "48": "logo/icons/icon48.png",
      "128": "logo/icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["logo/logo.jpg", "logo/icons/*.png"],
      "matches": ["*://www.youtube.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
